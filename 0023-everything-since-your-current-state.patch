 .../features/mission-control/task-card.tsx    | 17 ++++-
 2 files changed, 87 insertions(+), 5 deletions(-)

diff --git a/apps/api/src/modules/mission-control/mission-control.module.ts b/apps/api/src/modules/mission-control/mission-control.module.ts
