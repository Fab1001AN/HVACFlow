From f08ada454b8b60d3cb09ba96e8b9618399f9a85e Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Thu, 16 Jul 2026 11:34:35 +0000
Subject: [PATCH] Reorder departments in the sidebar's Departments section

New order: Purchasing, Engineering, Fabrication, Assembly, Piping,
Electrical, Painting, Miscellaneous Finishing, Testing & Quality,
Shipping.

Two notes on what I assumed:
- Renamed 'Dispatch' to 'Shipping' (same department, same code 'LOG',
  just the display name) since that's the name given in the requested
  order - existing data isn't affected since everything references
  departments by id, never by name or code.
- 'Miscellaneous Finishing' wasn't in the given list - kept it rather
  than assume it should be removed, placed between Painting and
  Testing & Quality where it was before.

Pure data change (sortOrder + one name), no schema/migration needed -
just re-run the seed.
---
 prisma/seed.ts | 16 ++++++++--------
 1 file changed, 8 insertions(+), 8 deletions(-)

diff --git a/prisma/seed.ts b/prisma/seed.ts
index fb3d4b6..83d251e 100644
--- a/prisma/seed.ts
+++ b/prisma/seed.ts
@@ -253,16 +253,16 @@ async function main() {
   console.log('Creating departments...');
 
   const departmentData = [
-    { name: 'Engineering', code: 'ENG', color: '#0ea5e9', sortOrder: 1 },
+    { name: 'Purchasing', code: 'PURCH', color: '#f59e0b', sortOrder: 1 },
+    { name: 'Engineering', code: 'ENG', color: '#0ea5e9', sortOrder: 2 },
     { name: 'Fabrication', code: 'FAB', color: '#6366f1', sortOrder: 3 },
-    { name: 'Purchasing', code: 'PURCH', color: '#f59e0b', sortOrder: 4 },
-    { name: 'Assembly', code: 'ASSY', color: '#10b981', sortOrder: 5 },
+    { name: 'Assembly', code: 'ASSY', color: '#10b981', sortOrder: 4 },
+    { name: 'Piping', code: 'PIPE', color: '#06b6d4', sortOrder: 5 },
     { name: 'Electrical', code: 'ELEC', color: '#8b5cf6', sortOrder: 6 },
-    { name: 'Piping', code: 'PIPE', color: '#06b6d4', sortOrder: 7 },
-    { name: 'Painting', code: 'PAINT', color: '#ec4899', sortOrder: 8 },
-    { name: 'Miscellaneous Finishing', code: 'MISC', color: '#a855f7', sortOrder: 9 },
-    { name: 'Testing & Quality', code: 'QA', color: '#14b8a6', sortOrder: 10 },
-    { name: 'Dispatch', code: 'LOG', color: '#64748b', sortOrder: 11 },
+    { name: 'Painting', code: 'PAINT', color: '#ec4899', sortOrder: 7 },
+    { name: 'Miscellaneous Finishing', code: 'MISC', color: '#a855f7', sortOrder: 8 },
+    { name: 'Testing & Quality', code: 'QA', color: '#14b8a6', sortOrder: 9 },
+    { name: 'Shipping', code: 'LOG', color: '#64748b', sortOrder: 10 },
   ];
 
   const departments: Record<string, string> = {};
