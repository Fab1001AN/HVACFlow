# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=hvacflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=hvacflow
POSTGRES_PORT=5432
DATABASE_URL="postgresql://hvacflow:change_me_in_production@localhost:5432/hvacflow?schema=public"

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API (NestJS) ────────────────────────────────────────────
API_PORT=4000
API_PREFIX=api/v1
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_64_chars_minimum_for_production_security
JWT_REFRESH_SECRET=change_me_refresh_secret_64_chars_minimum_for_production_security
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Web (Next.js) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
