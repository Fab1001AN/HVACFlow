// HVACFlow — Prisma Schema
// Version 2.0 — Full Configurability Edition
// PostgreSQL 16

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Fixed Engine Enums ───────────────────────────────────────────────────────
// These are the ONLY fixed values in the system.
// Everything else is configurable data in tables.

enum TaskStatus {
  Pending
  Ready
  InProgress
  PendingVerification
  Completed
  OnHold
  Rejected
}

enum OrderStatus {
  Draft
  Confirmed
  InProduction
  Completed
  Cancelled
}

enum EngineeringStatus {
  NotStarted
  SubmittalReceived
  DesigningStarted
  UnitDesignCompleted
  DrawingsCompleted
  ProgrammingCompleted
  ReleasedToManufacturing
}

enum ProductionReleaseStatus {
  AwaitingRelease
  Planned
  Released
  Started
  OnHold
}

enum UnitStatus {
  Planned
  InProgress
  Completed
  OnHold
  Dispatched
  Cancelled
}

enum PartStatus {
  Pending
  InProgress
  Completed
  OnHold
  Rejected
}

enum AppliesTo {
  PART
  UNIT
}

enum RouteTargetType {
  UNIT_TYPE
  PART_TYPE
}

// ─── Identity & Access ────────────────────────────────────────────────────────

// Singleton row (always id = "default") holding the customer-editable
// branding for this deployment. Since each customer gets their own
// separate deployment (own database) rather than shared multi-tenant
// infrastructure, one row per install is all this needs - no
// organizationId scoping required anywhere else.
model OrganizationSettings {
  id        String   @id @default("default")
  name      String   @default("HVACFlow")
  updatedAt DateTime @updatedAt

  @@map("organization_settings")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  roles                   UserRole[]
  departments             UserDepartment[]
  preferences             UserPreference?
  assignedTasks           ProductionTask[]    @relation("AssignedUser")
  verifiedTasks           ProductionTask[]    @relation("VerifiedByUser")
  createdTasks            ProductionTask[]    @relation("CreatedByUser")
  updatedTasks            ProductionTask[]    @relation("UpdatedByUser")
  taskStatusChanges       TaskStatusHistory[]
  checklistCompletions    ChecklistResponse[]
  createdUnits            Unit[]
  createdParts            Part[]
  unitComments            UnitComment[]
  vendorParts             VendorPart[]
  activityLogs            ActivityLog[]
  reworkAssigned          UnitRework[] @relation("ReworkAssignedTo")
  reworkCreated           UnitRework[] @relation("ReworkCreatedBy")
  shipmentsCreated        ShipmentRecord[]
  impersonationsMade      ImpersonationAudit[] @relation("ImpersonationAdmin")
  impersonationsReceived  ImpersonationAudit[] @relation("ImpersonationTarget")
  auditLogs               AuditLog[]           @relation("AuditActor")
  vendorDocsUploaded      VendorPartDocument[] @relation("VendorDocUploader")

  @@map("users")
}

// Records every "view as" / impersonation preview an admin starts, so
// there is an accountability trail of who previewed whom and when. The
// preview itself is read-only (enforced by ImpersonationGuard); this table
// exists purely for auditing. Deliberately separate from ActivityLog,
// which is unit-scoped and can't represent a user-level event. Rows are
// retained even if a user is later soft-deleted (SetNull) so the history
// isn't lost - the audit outlives the account.
model ImpersonationAudit {
  id             String   @id @default(uuid())
  adminId        String?
  targetUserId   String?
  adminName      String   // denormalised snapshot so the log survives account deletion
  targetUserName String
  createdAt      DateTime @default(now())

  admin      User? @relation("ImpersonationAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  targetUser User? @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([adminId, createdAt])
  @@map("impersonation_audits")
}

// System-wide audit trail: one row per successful mutating request
// (create/update/delete on any entity), captured automatically by
// AuditLogInterceptor. Compact by design - who, what action, which
// entity, when - not a full field-level diff. Admin-only to read.
// actorName is snapshotted so the entry survives if the user is later
// deleted (actorId FK is SetNull).
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorName  String
  action     String   // HTTP verb mapped to CREATE / UPDATE / DELETE
  entity     String   // resource collection, e.g. "departments", "process-routes"
  entityId   String?  // the affected record id, when present in the route
  method     String   // raw HTTP method
  path       String   // request path, for disambiguation
  statusCode Int
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([entity, createdAt])
  @@map("audit_logs")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions      RolePermission[]
  users            UserRole[]
  dashboardConfig  RoleDashboardConfig?

  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique
  description String?
  category    String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserDepartment {
  userId       String
  departmentId String
  isPrimary    Boolean @default(false)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@map("user_departments")
}

// ─── Configurable Priority Levels ────────────────────────────────────────────
// Replaces the hardcoded Low/Normal/High/Urgent enum.
// All priority dropdowns in the application read from this table.

model PriorityLevel {
  id        String  @id @default(uuid())
  name      String  @unique
  color     String?
  sortOrder Int
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  orders            Order[]
  units             Unit[]
  tasks             ProductionTask[]
  processDefaults   ProcessDefinition[]

  @@map("priority_levels")
}

// ─── Manufacturing Hierarchy ──────────────────────────────────────────────────

model Customer {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique
  contactInfo Json?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  projects Project[]

  @@map("customers")
}

model Project {
  id            String    @id @default(uuid())
  customerId    String
  name          String
  code          String    @unique
  startDate     DateTime?
  targetEndDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  customer Customer @relation(fields: [customerId], references: [id])
  orders   Order[]

  @@index([customerId])
  @@map("projects")
}

model Order {
  id                    String      @id @default(uuid())
  projectId             String
  orderNumber           String      @unique
  priorityLevelId       String
  status                OrderStatus @default(Draft)
  requestedDeliveryDate DateTime?
  notes                 String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  deletedAt             DateTime?

  project       Project       @relation(fields: [projectId], references: [id])
  priorityLevel PriorityLevel @relation(fields: [priorityLevelId], references: [id])
  units         Unit[]

  @@index([projectId])
  @@index([status])
  @@map("orders")
}

// ─── Configurable Type Catalogs ───────────────────────────────────────────────

model UnitType {
  id        String  @id @default(uuid())
  name      String
  code      String  @unique
  isActive  Boolean @default(true)

  units        Unit[]
  processRoutes ProcessRoute[]
  composition   UnitTypeComposition[]

  @@map("unit_types")
}

enum PartSourceType {
  Fabricated
  Vendor
}

model PartType {
  id         String         @id @default(uuid())
  name       String
  code       String         @unique
  isActive   Boolean        @default(true)
  sourceType PartSourceType @default(Fabricated)

  parts         Part[]
  processRoutes ProcessRoute[]
  compositions  UnitTypeComposition[]
  vendorParts   VendorPart[]

  @@map("part_types")
}

// ─── Unit Composition — defines which PartTypes belong to each UnitType ───────

model UnitTypeComposition {
  id              String  @id @default(uuid())
  unitTypeId      String
  partTypeId      String
  defaultQuantity Int     @default(1)
  isOptional      Boolean @default(false)
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)

  unitType UnitType @relation(fields: [unitTypeId], references: [id])
  partType PartType @relation(fields: [partTypeId], references: [id])

  @@unique([unitTypeId, partTypeId])
  @@index([unitTypeId])
  @@map("unit_type_compositions")
}

model Unit {
  id                       String     @id @default(uuid())
  orderId                  String?
  unitTypeId               String
  priorityLevelId          String?
  currentDepartmentId      String?
  serialNumber             String     @unique
  displayName              String?
  specifications           Json?
  plannedStartDate         DateTime? // legacy; no longer used by planning UI
  productionMonth          DateTime?
  dueDate                  DateTime?
  priorityPosition         Int        @default(0)
  currentStage             String?
  engineeringStatus        EngineeringStatus @default(NotStarted)
  productionReleaseStatus  ProductionReleaseStatus @default(AwaitingRelease)
  releasedAt               DateTime?
  releasedByUserId         String?
  manufacturingStartedAt   DateTime?
  assignedTeamName         String? // captured when Assembly clicks "Start Building Unit"
  assemblyStartedAt        DateTime?
  // New generic engine's position tracker - nullable and untouched by
  // the existing Engineering/Planner/Manager/Assembly flow for now.
  // Only units created/advanced through the new generic
  // /units/:id/workflow/* endpoints ever set this.
  currentWorkflowStageId   String?
  isBlocked                Boolean    @default(false)
  holdReason               String?
  oneDriveFolderUrl        String?
  submittalReceived        Boolean    @default(false)
  designComplete           Boolean    @default(false)
  drawingsAvailable        Boolean    @default(false)
  programmingFilesComplete Boolean    @default(false)
  cuttingProgramsAvailable Boolean    @default(false)
  progressPercentage       Decimal    @default(0) @db.Decimal(5, 2)
  status                   UnitStatus @default(Planned)
  createdByUserId          String
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  deletedAt                DateTime?

  order             Order?            @relation(fields: [orderId], references: [id])
  unitType          UnitType          @relation(fields: [unitTypeId], references: [id])
  priorityLevel     PriorityLevel?    @relation(fields: [priorityLevelId], references: [id])
  currentDepartment Department?       @relation(fields: [currentDepartmentId], references: [id])
  createdBy         User              @relation(fields: [createdByUserId], references: [id])
  parts             Part[]
  tasks             ProductionTask[] @relation("UnitTasks")
  comments          UnitComment[]
  vendorParts       VendorPart[]
  activityLogs      ActivityLog[]
  reworks           UnitRework[]
  shipments         ShipmentRecord[]
  currentWorkflowStage WorkflowStage? @relation("UnitWorkflowStage", fields: [currentWorkflowStageId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([priorityLevelId])
  @@index([currentDepartmentId])
  @@index([plannedStartDate])
  @@index([productionMonth])
  @@index([engineeringStatus])
  @@index([productionReleaseStatus])
  @@index([dueDate])
  @@index([status])
  @@map("units")
}

// Unified, unit-level "what happened and when" timeline - the single
// source of truth an audit trail needs, instead of scattered signals
// (task.completedAt, unit comments, etc.) that each only tell part of
// the story. Every meaningful business event on a unit gets one entry
// here, in plain language, so a manager or director can see the whole
// history of a unit in one place without cross-referencing five pages.
enum ActivityAction {
  UnitCreated
  EngineeringAdvanced
  UnitPlanned
  UnitReleasedToProduction
  ManufacturingStarted
  AssemblyStarted
  TaskCompleted
  TaskReopened
  DelayReported
  VendorPartReceived
  VendorPartLogged
  UnitBlocked
  UnitUnblocked
  WorkflowStageAdvanced
  WorkflowStageMovedBack
  WorkflowStageSet
  ReworkCreated
  ReworkCompleted
  ShipmentLogged
}

model ActivityLog {
  id          String         @id @default(uuid())
  unitId      String
  userId      String?
  action      ActivityAction
  description String
  metadata    Json?
  createdAt   DateTime       @default(now())

  unit Unit  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([unitId, createdAt])
  @@map("activity_logs")
}

model UnitComment {
  id        String   @id @default(uuid())
  unitId    String
  userId    String
  message   String
  isDelay   Boolean  @default(false)
  createdAt DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([unitId, createdAt])
  @@map("unit_comments")
}

// Vendor-supplied parts (HX coils, compressors, motors, etc.) tracked
// separately from fabricated Parts - they don't get routed through
// process/task workflow at all, just a received/pending status and
// dates. Added either by a Purchasing user (drag-drop from the vendor
// part-type palette) or by Assembly directly if the Purchasing
// department is toggled off.
enum ReworkStatus {
  Open
  Completed
}

// Deliberately separate from WorkflowStage/currentWorkflowStageId - a
// completed unit is never reopened (per this project's own rule), so
// post-shipment rework can't be "move the unit backward." Instead it's
// its own simple record linked to the original unit: what's wrong, who's
// fixing it, done or not, when it went back out. No internal stages of
// its own - the person handling it might be pulled from any department,
// there's no fixed sequence to enforce here the way there is for normal
// production.
model UnitRework {
  id                String       @id @default(uuid())
  unitId            String
  issue             String
  assignedToUserId  String?
  status            ReworkStatus @default(Open)
  notes             String?
  completedAt       DateTime?
  reshippedAt       DateTime?
  createdByUserId   String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  unit        Unit  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  assignedTo  User? @relation("ReworkAssignedTo", fields: [assignedToUserId], references: [id])
  createdBy   User  @relation("ReworkCreatedBy", fields: [createdByUserId], references: [id])

  @@index([unitId])
  @@map("unit_reworks")
}

// One-to-many rather than one-to-one - a unit that goes through Rework
// after its first shipment gets a second ShipmentRecord for the
// reship, not an edited version of the first. Keeps a real history of
// every time this unit actually left the building.
model ShipmentRecord {
  id                   String    @id @default(uuid())
  unitId               String
  carrierName          String?
  shipDate             DateTime?
  truckNumber          String?
  trackingNumber       String? // BOL / freight reference number
  driverName           String?
  destinationConfirmed Boolean   @default(false)
  receivedBySignature  String?
  notes                String?
  createdByUserId      String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  unit      Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdByUserId], references: [id])

  @@index([unitId])
  @@map("shipment_records")
}

model VendorPart {
  id                  String    @id @default(uuid())
  unitId              String
  partTypeId          String
  isReceived          Boolean   @default(false)
  expectedArrivalDate DateTime?
  receivedDate        DateTime?
  // Supplier's purchase-order / reference number. Free text because every
  // supplier formats theirs differently. Useful on its own for traceability,
  // and it's what lets a delivery note be matched back to the right part.
  poReference         String?
  addedByUserId       String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  unit          Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  partType      PartType @relation(fields: [partTypeId], references: [id])
  addedByUser   User     @relation(fields: [addedByUserId], references: [id])
  documents     VendorPartDocumentLink[]

  @@index([unitId])
  @@index([poReference])
  @@map("vendor_parts")
}

// A piece of supporting evidence for vendor deliveries - a photographed or
// screenshotted delivery note, order confirmation, supplier email, etc.
//
// Stored as bytes IN THE DATABASE rather than on disk, deliberately: the
// backup script dumps the database only, so filesystem uploads would be
// silently missing from every backup. Keeping them here means proof is
// covered by the existing backup/restore with no extra moving parts, and
// there are no orphaned files to clean up. Delivery notes are small, so the
// size cost is acceptable.
model VendorPartDocument {
  id             String   @id @default(uuid())
  fileName       String
  mimeType       String
  sizeBytes      Int
  data           Bytes
  note           String?
  uploadedById   String?
  uploadedByName String   // snapshot, so the record survives user deletion
  createdAt      DateTime @default(now())

  uploadedBy   User?                    @relation("VendorDocUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  vendorParts  VendorPartDocumentLink[]

  @@index([createdAt])
  @@map("vendor_part_documents")
}

// One delivery note often covers several parts, and a part can accumulate
// several documents over time - so this is many-to-many rather than a single
// foreign key.
model VendorPartDocumentLink {
  vendorPartId String
  documentId   String

  vendorPart VendorPart         @relation(fields: [vendorPartId], references: [id], onDelete: Cascade)
  document   VendorPartDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([vendorPartId, documentId])
  @@index([documentId])
  @@map("vendor_part_document_links")
}

model Part {
  id                 String     @id @default(uuid())
  unitId             String
  partTypeId         String
  identifier         String
  quantity           Int        @default(1)
  specifications     Json?
  progressPercentage Decimal    @default(0) @db.Decimal(5, 2)
  status             PartStatus @default(Pending)
  createdByUserId    String
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  unit      Unit             @relation(fields: [unitId], references: [id])
  partType  PartType         @relation(fields: [partTypeId], references: [id])
  createdBy User             @relation(fields: [createdByUserId], references: [id])
  tasks     ProductionTask[] @relation("PartTasks")

  @@unique([unitId, identifier])
  @@index([unitId])
  @@index([status])
  @@map("parts")
}

// ─── Configuration — Departments, Processes, Routes ──────────────────────────

model Department {
  id        String  @id @default(uuid())
  name      String  @unique
  code      String  @unique
  color     String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              UserDepartment[]
  processDefinitions ProcessDefinition[]
  machines           Machine[]
  tasks              ProductionTask[]
  currentUnits       Unit[]
  workflowStages     WorkflowStage[]

  @@map("departments")
}

// Step 2 of the workflow-configurability plan: a generic, admin-defined
// pipeline stage - the building block that will eventually replace the
// hardcoded Planner -> Manager -> Fabrication -> Assembly sequence
// (Unit.engineeringStatus / productionReleaseStatus / etc.). Built and
// shipped as new, additive infrastructure FIRST, proven to work on its
// own via its own admin UI - migrating the real, currently-working
// pipeline onto it is a deliberately separate, later step (Step 3), not
// bundled into this one. Ripping out a working state machine and a
// brand new one in the same change is exactly how you end up unable to
// tell which part broke.
model WorkflowStage {
  id                 String   @id @default(uuid())
  name               String   @unique
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  departmentId       String? // null = cross-department stage (e.g. a Planner/Manager-style review step, not tied to shop-floor work)
  requiredPermission String  // permission code needed to advance a unit out of this stage
  actionLabel        String  @default("Advance") // button text shown for the advance action
  allowsBackward     Boolean @default(false) // can a unit be sent back to the previous stage from here
  // A unit on a terminal stage is finished as far as active production
  // dashboards care - it drops off the Director/Manager/Planner/
  // Designing work lists. Which stages count as terminal is
  // deployment-configurable rather than hardcoded by name, so a
  // white-label customer can define their own end-of-line (e.g. one
  // shop's "done" is Dispatch, another's is a later Shipped or Installed
  // stage) without touching code.
  isTerminal         Boolean @default(false)
  // Enforces the "all parts must be Completed before a unit can enter this
  // stage" business rule. Previously hardcoded to the stage literally named
  // "Unit Completed"; now any deployment can put that quality gate wherever
  // its pipeline needs it (or nowhere) without touching code.
  gatesOnPartsComplete Boolean @default(false)
  // Enforces "all bought-in vendor parts must be received before a unit can
  // enter this stage". Off by default. A shop that can't finish/ship a unit
  // while a purchased component (compressor, controller, etc.) is still
  // outstanding turns this on for its completion or dispatch stage; a shop
  // that fits vendor parts on a parallel track leaves it off. Separate from
  // gatesOnPartsComplete because manufactured Parts and bought-in VendorParts
  // are tracked independently.
  gatesOnVendorPartsReceived Boolean @default(false)
  // Marks the end of the Production Manager's / Assembly's active
  // responsibility. A unit at or before this stage's position still shows
  // on the Manager and Assembly WIP views; past it, it's QC/dispatch's
  // concern. Previously hardcoded to "Assembly Started"; now flag-driven so
  // a renamed or restructured pipeline still resolves the boundary.
  isManagerBoundary  Boolean @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  units      Unit[]       @relation("UnitWorkflowStage")

  @@index([sortOrder])
  @@map("workflow_stages")
}

model ProcessDefinition {
  id                       String     @id @default(uuid())
  departmentId             String
  name                     String     @unique
  code                     String     @unique
  appliesTo                AppliesTo
  requiresChecklist        Boolean    @default(false)
  requiresVerification     Boolean    @default(false)
  defaultEstimatedMinutes  Int?
  defaultPriorityLevelId   String?
  weight                   Decimal    @default(1.0) @db.Decimal(5, 2)
  isActive                 Boolean    @default(true)
  isOptional               Boolean    @default(false)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  department           Department         @relation(fields: [departmentId], references: [id])
  defaultPriorityLevel PriorityLevel?     @relation(fields: [defaultPriorityLevelId], references: [id])
  processRoutes        ProcessRoute[]
  tasks                ProductionTask[]
  checklistTemplates   ChecklistTemplate[]

  @@index([departmentId])
  @@map("process_definitions")
}

model ProcessRoute {
  id                  String          @id @default(uuid())
  targetType          RouteTargetType
  unitTypeId          String?
  partTypeId          String?
  processDefinitionId String
  sequenceOrder       Int
  isOptional          Boolean         @default(false)
  isActive            Boolean         @default(true)

  unitType          UnitType?         @relation(fields: [unitTypeId], references: [id])
  partType          PartType?         @relation(fields: [partTypeId], references: [id])
  processDefinition ProcessDefinition @relation(fields: [processDefinitionId], references: [id])

  @@index([unitTypeId])
  @@index([partTypeId])
  @@index([processDefinitionId])
  @@map("process_routes")
}

model Machine {
  id           String  @id @default(uuid())
  departmentId String
  name         String
  code         String  @unique
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department       @relation(fields: [departmentId], references: [id])
  tasks      ProductionTask[]

  @@index([departmentId])
  @@map("machines")
}

// ─── Checklists ───────────────────────────────────────────────────────────────

model ChecklistTemplate {
  id                  String  @id @default(uuid())
  processDefinitionId String
  name                String
  isActive            Boolean @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  processDefinition ProcessDefinition      @relation(fields: [processDefinitionId], references: [id])
  items             ChecklistItemTemplate[]

  @@map("checklist_templates")
}

model ChecklistItemTemplate {
  id                  String  @id @default(uuid())
  checklistTemplateId String
  label               String
  sortOrder           Int     @default(0)
  isRequired          Boolean @default(true)

  checklistTemplate ChecklistTemplate   @relation(fields: [checklistTemplateId], references: [id])
  responses         ChecklistResponse[]

  @@map("checklist_item_templates")
}

model ChecklistResponse {
  id                      String    @id @default(uuid())
  productionTaskId        String
  checklistItemTemplateId String
  isChecked               Boolean   @default(false)
  completedByUserId       String?
  completedAt             DateTime?

  productionTask       ProductionTask        @relation(fields: [productionTaskId], references: [id], onDelete: Cascade)
  checklistItemTemplate ChecklistItemTemplate @relation(fields: [checklistItemTemplateId], references: [id])
  completedBy          User?                 @relation(fields: [completedByUserId], references: [id])

  @@unique([productionTaskId, checklistItemTemplateId])
  @@index([productionTaskId])
  @@map("checklist_responses")
}

// ─── Production Task Engine ───────────────────────────────────────────────────
// Single universal table for every manufacturing operation.

model ProductionTask {
  id                      String     @id @default(uuid())
  partId                  String?
  unitId                  String?
  departmentId            String
  processDefinitionId     String
  sequenceOrder           Int
  parentTaskId            String?
  nextTaskId              String?
  status                  TaskStatus @default(Pending)
  priorityLevelId         String
  assignedUserId          String?
  verifiedByUserId        String?
  machineId               String?
  estimatedDurationMinutes Int?
  actualDurationMinutes   Int?
  startedAt               DateTime?
  completedAt             DateTime?
  verifiedAt              DateTime?
  notes                   String?
  createdByUserId         String
  updatedByUserId         String
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  // Hierarchy relations
  part  Part? @relation("PartTasks", fields: [partId], references: [id])
  unit  Unit? @relation("UnitTasks", fields: [unitId], references: [id])

  // Config relations
  department        Department        @relation(fields: [departmentId], references: [id])
  processDefinition ProcessDefinition @relation(fields: [processDefinitionId], references: [id])
  priorityLevel     PriorityLevel     @relation(fields: [priorityLevelId], references: [id])
  machine           Machine?          @relation(fields: [machineId], references: [id])

  // User relations
  assignedUser   User? @relation("AssignedUser", fields: [assignedUserId], references: [id])
  verifiedByUser User? @relation("VerifiedByUser", fields: [verifiedByUserId], references: [id])
  createdBy      User  @relation("CreatedByUser", fields: [createdByUserId], references: [id])
  updatedBy      User  @relation("UpdatedByUser", fields: [updatedByUserId], references: [id])

  // Self-referencing task graph
  parentTask ProductionTask?  @relation("TaskParent", fields: [parentTaskId], references: [id])
  childTasks ProductionTask[] @relation("TaskParent")
  nextTask   ProductionTask?  @relation("TaskSequence", fields: [nextTaskId], references: [id])
  prevTasks  ProductionTask[] @relation("TaskSequence")

  // Sub-entities
  statusHistory     TaskStatusHistory[]
  checklistResponses ChecklistResponse[]

  @@index([departmentId, status])
  @@index([partId])
  @@index([unitId])
  @@index([assignedUserId, status])
  @@index([parentTaskId])
  @@index([nextTaskId])
  @@index([status, priorityLevelId])
  @@map("production_tasks")
}

model TaskStatusHistory {
  id               String     @id @default(uuid())
  productionTaskId String
  fromStatus       TaskStatus?
  toStatus         TaskStatus
  changedByUserId  String
  changedAt        DateTime   @default(now())
  note             String?

  productionTask ProductionTask @relation(fields: [productionTaskId], references: [id], onDelete: Cascade)
  changedBy      User           @relation(fields: [changedByUserId], references: [id])

  @@index([productionTaskId, changedAt])
  @@map("task_status_history")
}

// ─── Dashboard Configuration ──────────────────────────────────────────────────

model UserPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  preferences Json     @default("{}")
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model RoleDashboardConfig {
  id        String   @id @default(uuid())
  roleId    String   @unique
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("role_dashboard_configs")
}
