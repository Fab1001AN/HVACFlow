From fc718967f0c8e6354f961e6be422c03c6d2b8752 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Thu, 16 Jul 2026 00:24:37 +0000
Subject: [PATCH 1/2] Fix authorization bypass in mission-control board
 department filtering

Found while extending this endpoint for the new Shop Floor / Supervisor
Dashboard split. getBoard() built its department where-clause by
spreading both the caller's allowed-department restriction and an
explicit ?departmentId= filter into the same object literal under the
same "id" key - the second spread silently overwrote the first, so the
permission restriction never actually applied whenever a departmentId
filter was present. A department-scoped user (task:view only, no
task:view-all) could request any other department's board just by
passing its id in the query string and see its live task data.

Fixed: an explicit departmentId filter now intersects with the caller's
actual allowed departments instead of replacing that check - requesting
a department outside their scope returns an empty board, not a bypass.
---
 .../mission-control/mission-control.module.ts  | 18 ++++++++++++++++--
 1 file changed, 16 insertions(+), 2 deletions(-)

diff --git a/apps/api/src/modules/mission-control/mission-control.module.ts b/apps/api/src/modules/mission-control/mission-control.module.ts
index a91f075..fbe3122 100644
--- a/apps/api/src/modules/mission-control/mission-control.module.ts
+++ b/apps/api/src/modules/mission-control/mission-control.module.ts
@@ -25,12 +25,26 @@ export class MissionControlService {
       ? undefined // all departments
       : callerDeptIds;
 
+    // An explicit ?departmentId= filter must narrow within the caller's
+    // allowed departments, never replace that restriction - previously
+    // both conditions spread the same `id` key into one where object,
+    // so the filter silently overrode the permission check entirely: a
+    // department-scoped user could request any other department's board
+    // just by passing its id in the query string.
+    let allowedDeptIds: string[] | undefined = effectiveDeptIds;
+    if (filters.departmentId) {
+      if (!allowedDeptIds || allowedDeptIds.includes(filters.departmentId)) {
+        allowedDeptIds = [filters.departmentId];
+      } else {
+        allowedDeptIds = []; // requested a department outside their scope - show nothing, don't leak it
+      }
+    }
+
     // Load departments in sorted order (Kanban column order)
     const departments = await this.prisma.department.findMany({
       where: {
         isActive: true,
-        ...(effectiveDeptIds ? { id: { in: effectiveDeptIds } } : {}),
-        ...(filters.departmentId ? { id: filters.departmentId } : {}),
+        ...(allowedDeptIds ? { id: { in: allowedDeptIds } } : {}),
       },
       orderBy: { sortOrder: 'asc' },
     });
